# --- LLM (required) ---
# Get a free API key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL_FAST=gemini-2.5-flash
# Most free-tier accounts have Pro disabled. Flash works well here.
# Override to gemini-2.5-pro if you have paid access.
GEMINI_MODEL_SMART=gemini-2.5-flash

# --- Web search (optional, Phase 6c) ---
# Set ONE of these to ground POI / accommodation suggestions in real results.
# Without any key, agents fall back to LLM-only output (still works).
# Free tiers:  Tavily ~1k/mo  |  Serper ~2.5k/mo  |  Brave ~2k/mo
TAVILY_API_KEY=
SERPER_API_KEY=
BRAVE_API_KEY=

# --- Maps (optional, Phase 6d) ---
# Currently a stub; v2 will hit Google Places for hours/coordinates.
GOOGLE_MAPS_API_KEY=

# --- Runtime ---
TRIP_PLANNER_TRACE_DIR=traces
TRIP_PLANNER_COST_CEILING_USD=0.50
# Set to 1 to run specialist agents in parallel (only if your Gemini account
# has higher RPM than the free-tier 5 RPM cap).
TRIP_PLANNER_PARALLEL=0
